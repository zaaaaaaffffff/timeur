      },
      "source": [
        "print(\"=== Smart Purchase Advisor ===\")\n",
        "\n",
        "# Get financial information\n",
        "available_money = float(input(\"How much money do you have available? $\"))\n",
        "purchase_price = float(input(\"How much does the item cost? $\"))\n",
        "monthly_income = float(input(\"What's your monthly income? $\"))\n",
        "\n",
        "# Calculate affordability percentage\n",
        "affordability_ratio = purchase_price / available_money\n",
        "\n",
        "if purchase_price > available_money:\n",
        "    print(\"You can't afford this purchase right now.\")\n",
        "elif affordability_ratio > 0.5:\n",
        "    print(\"Major purchase - think carefully before buying.\")\n",
        "elif affordability_ratio > 0.25:\n",
        "    print(\"Significant expense - consider your budget.\")\n",
        "elif income_ratio > 0.5:\n",
        "    print(\"This is expensive compared to your monthly income.\")\n",
        "elif affordability_ratio > 0.10:\n",
        "    print(\"Moderate expense - seems manageable.\")\n",
        "else:\n",
        "    print(\"Minor expense - you can buy this without worry!\")"
      ],
