        "# --- Expense categorisation logic ---\n",
        "expense_ratio = expense_amount / monthly_income  # percentage of income spent\n",
        "expense_percent = expense_ratio * 100  # convert to %\n",
        "\n",
        "if expense_ratio > 0.5:\n",
        "    category = \"Major purchase - think carefully\"\n",
        "elif expense_ratio > 0.25:\n",
        "    category = \"Significant expense\"\n",
        "elif expense_ratio > 0.10:\n",
        "    category = \"Moderate expense\"\n",
        "else:\n",
        "    category = \"Minor expense - within budget\"\n",
        "\n",
        "# --- Helpful feedback based on category ---\n",
        "if expense_ratio > 0.5:\n",
        "    feedback = \"This is a large portion of your monthly income. Consider waiting or budgeting first.\"\n",
        "elif expense_ratio > 0.25:\n",
        "    feedback = \"This is a considerable expense. Make sure other bills are covered.\"\n",
        "elif expense_ratio > 0.10:\n",
        "    feedback = \"Manageable spending. Keep an eye on other expenses.\"\n",
        "else:\n",
        "    feedback = \"You're keeping your spending low. Good job!\"\n",
        "\n",
        "# Display results\n",
        "print(f\"\\nExpense recorded: ${expense_amount:.2f} for {expense_description}\")\n",
        "print(f\"Category: {category}\")\n",
        "print(f\"Budget usage: {expense_percent:.1f}% of monthly income\")\n",
        "print(f\"Advice: {feedback}\")"
